AUTH_SECRET=replace-with-a-long-random-string
AUTH_GITHUB_ID=replace-with-your-github-oauth-app-id
AUTH_GITHUB_SECRET=replace-with-your-github-oauth-app-secret

# Local development runtime and migration connection
DATABASE_URL=postgres://postgres:postgres@localhost:5432/local

# Optional: use a direct connection for Drizzle migrations and Studio in production
# For Supabase on Vercel, keep DATABASE_URL on the pooler URL and set DIRECT_DATABASE_URL
# to the direct database URL when needed.
DIRECT_DATABASE_URL=
